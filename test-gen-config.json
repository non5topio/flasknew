{
    "enabled": "true",
    "increase-coverage": {
      "project-name": "flasknew",
      "target-branches": [
        "main"
      ],
      "test-env-docker-stage": "test",
      "build-test-env-docker-stage-script-path": "tool/build-test-env-docker-stage.sh",
      "test-files-folders": [
        "."
      ],
      "source-test-file-paths": [
        {
          "source-file-path": "app.py",
          "test-file-path": "test_app.py"
        }
      ],
      "test-command": "pytest --cov=. --cov-report=xml --cov-report=term",
      "coverage-type": "cobertura",
      "code-coverage-report-path": "coverage.xml",
      "desired-coverage": 90,
      "max-iterations": 1,
      "max-number-of-test-cases": 6
    }
}